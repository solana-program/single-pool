{
  "name": "@solana/spl-single-pool",
  "version": "2.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/solana-program/single-pool",
    "directory": "clients/js"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/mjs/index.js",
  "exports": {
    ".": {
      "import": "./dist/mjs/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "scripts": {
    "prepublishOnly": "pnpm build",
    "clean": "rm -fr dist/*",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig-cjs.json && ./ts-fixup.sh",
    "test": "tsc -p tsconfig.json",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@solana/prettier-config-solana": "^0.0.6",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@solana/addresses": "6.8.0",
    "@solana/functional": "6.8.0",
    "@solana/instructions": "6.8.0",
    "@solana/instruction-plans": "6.8.0",
    "@solana/rpc-api": "6.8.0",
    "@solana/rpc-spec": "6.8.0",
    "@solana/transaction-messages": "6.7.0"
  }
}
